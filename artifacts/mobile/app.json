{
  "expo": {
    "name": "First Booyah",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D14"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#0D0D14",
      "package": "com.hindustan803200.mobile"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0D0D14"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "088d23f8-474d-4546-9a80-8b01ec914f9e"
      }
    },
    "owner": "hindustan803200"
  }
}
